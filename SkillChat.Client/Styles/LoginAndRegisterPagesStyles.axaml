<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia">

    <!--TextBlock-->
    <Style Selector="TextBlock.UpperWatermark">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontStyle" Value="Italic" />
    </Style>
    <Style Selector="TextBlock.Error">
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
    </Style>
    <Style Selector="TextBlock.ClearContainer">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Margin" Value="0,0,0,40" />
    </Style>
    <Style Selector="Button.ClearContainer">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="600" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,40" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <!--TextBox-->
    <Style Selector="TextBox.TextBoxEnterPages">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="BorderBrush" Value="{DynamicResource PageBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Height" Value="42" />
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Width" Value="220"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource PageBackgroundBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="TextBox.Base">
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style Selector="TextBox.Error">
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
    </Style>

    <!-- Suppress Fluent inner border on focus for login page textboxes -->
    <Style Selector="TextBox.TextBoxEnterPages /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.TextBoxEnterPages:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.TextBoxEnterPages:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBox.TextBoxEnterPages:focus-within /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!--Border-->
    <Style Selector="Border.BorderEnterPages">
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Width" Value="300" />
        <Setter Property="Height" Value="50" />
    </Style>
    <Style Selector="Border.Base">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
    </Style>
    <Style Selector="Border.Error">
        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
    </Style>

    <!--Image-->
    <Style Selector="Image.ImageTbx">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="IsVisible" Value="{Binding User.ErrorMessageLoginPage.IsError}"/>
        <Setter Property="Source">
            <Setter.Value>
                <svg:SvgImage Source="/Assets/atention.svg" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--CheckBox content styling for registration page-->
    <Style Selector="CheckBox /template/ ContentPresenter#ContentPresenter">
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        <Setter Property="TextBlock.FontSize" Value="12"/>
        <Setter Property="TextBlock.FontStyle" Value="Italic"/>
    </Style>

    <!--Button-->
    <Style Selector="Button.ButtonEnterPages /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
    </Style>
    <Style Selector="Button.ButtonEnterPages /template/ ContentPresenter">
        <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button.ButtonEnterPages">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryButtonTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="6" />
    </Style>

    <Style Selector="Button.ButtonEnterPages:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
    </Style>
    <Style Selector="Button.ButtonEnterPages:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
    </Style>

    <Style Selector="Button.ButtonEnterPages:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentPressedBrush}" />
    </Style>
    <Style Selector="Button.ButtonEnterPages:disabled /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentPressedBrush}" />
    </Style>


</Styles>
