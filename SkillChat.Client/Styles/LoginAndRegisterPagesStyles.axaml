<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia">

    <!--TextBlock-->
    <Style Selector="TextBlock.UpperWatermark">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource Violet_04Brush}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontStyle" Value="Italic" />
    </Style>
    <Style Selector="TextBlock.Error">
        <Setter Property="Foreground" Value="{DynamicResource Orange_02Brush}" />
    </Style>
    <Style Selector="TextBlock:ClearContainer">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Orange_02Brush}" />
        <Setter Property="Margin" Value="0,0,0,40" />
    </Style>

    <!--TextBox-->
    <Style Selector="TextBox.TextBoxEnterPages">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="BorderBrush" Value="{DynamicResource SystemRegionBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="Height" Value="42" />
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Width" Value="220"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{DynamicResource SystemRegionBrush}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>
    <Style Selector="TextBox.Base">
        <Setter Property="Foreground" Value="{DynamicResource Violet_02Brush}" />
    </Style>
    <Style Selector="TextBox.Error">
        <Setter Property="Foreground" Value="{DynamicResource Orange_01Brush}" />
    </Style>

    <Style Selector="TextBox.TextBoxEnterPages:focus /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style Selector="TextBox.TextBoxEnterPages:pointerover /template/ Border#PART_BorderElement">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!--Border-->
    <Style Selector="Border.BorderEnterPages">
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Width" Value="300" />
        <Setter Property="Height" Value="50" />
    </Style>
    <Style Selector="Border.Base">
        <Setter Property="BorderBrush" Value="{DynamicResource Violet_02Brush}"/>
    </Style>
    <Style Selector="Border.Error">
        <Setter Property="BorderBrush" Value="{DynamicResource Orange_02Brush}"/>
    </Style>

    <!--Image-->
    <Style Selector="Image.ImageTbx">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="IsVisible" Value="{Binding User.ErrorMessageLoginPage.IsError}"/>
        <Setter Property="Source">
            <Setter.Value>
                <svg:SvgImage Source="/Assets/atention.svg" />
            </Setter.Value>
        </Setter>
    </Style>

    <!--CheckBox content styling for registration page-->
    <Style Selector="CheckBox /template/ ContentPresenter#ContentPresenter">
        <Setter Property="TextBlock.Foreground" Value="{DynamicResource Violet_04Brush}"/>
        <Setter Property="TextBlock.FontSize" Value="12"/>
        <Setter Property="TextBlock.FontStyle" Value="Italic"/>
    </Style>

    <!--Button-->
    <Style Selector="Button.ButtonEnterPages /template/ ContentPresenter">
        <Setter Property="CornerRadius" Value="2" />
    </Style>
    <Style Selector="Button.ButtonEnterPages">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{DynamicResource SystemRegionBrush}" />
        <Setter Property="Background" Value="{DynamicResource Violet_02Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Violet_02Brush}" />
    </Style>

    <Style Selector="Button.ButtonEnterPages:pointerover">
        <Setter Property="Background" Value="{DynamicResource Violet_01Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Violet_01Brush}" />
    </Style>

    <Style Selector="Button.ButtonEnterPages:disabled">
        <Setter Property="Opacity" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Violet_01Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Violet_01Brush}" />
    </Style>


</Styles>
