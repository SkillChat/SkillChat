<Application
    x:Class="SkillChat.Client.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
    xmlns:local="clr-namespace:SkillChat.Client"
    xmlns:themes="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <themes:FluentTheme />
        <StyleInclude Source="/Assets/SkillChat.xaml" />
        <StyleInclude Source="/Styles/ProfileStyle.xaml" />
        <StyleInclude Source="/Styles/SettingsStyle.xaml" />
        <StyleInclude Source="/Styles/SendMessageStyle.xaml" />
        <StyleInclude Source="/Styles/MessageStyle.xaml" />
        <StyleInclude Source="/Styles/LoginAndRegisterPagesStyles.axaml" />
		<StyleInclude Source="/Styles/MenuStyles.axaml"/>
        <StyleInclude Source="/Styles/ConfirmationControlStyles.axaml"/>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Open Sans" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="Open Sans" />
        </Style>
    </Application.Styles>
</Application>
