<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:SkillChat.Client.ViewModel;assembly=SkillChat.Client.ViewModel"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="93"
             x:Class="SkillChat.Client.Views.Settings.More"
             Background="Transparent">
    <Design.DataContext>
        <viewModel:DesignMainWindowViewModel/>
    </Design.DataContext>
    <Border CornerRadius="2"
            Name="bord"
            automation:AutomationProperties.AutomationId="HeaderContextMenuRoot"
            IsVisible="{Binding SettingsViewModel.IsContextMenu}"
            Background="{DynamicResource SystemRegionBrush}"
            BorderBrush="{DynamicResource Orange_03Brush}"
            BorderThickness="1">
        <WrapPanel>

            <Button
                automation:AutomationProperties.AutomationId="HeaderSelectMessagesButton"
                Width="200"
                Height="30"
                BorderBrush="Transparent"
                HorizontalContentAlignment="Left"
                Background="Transparent"
                Cursor="Hand"
                Classes="SelectedMore"
                Command="{Binding SelectModeOn}">
                <Button.Content>
                    <TextBlock Text="Выбрать сообщения" FontWeight="400" FontSize="13" Padding="15 0" />
                </Button.Content>
            </Button>

            <Button
                automation:AutomationProperties.AutomationId="HeaderClearHistoryButton"
                Width="200"
                Height="30"
                BorderBrush="Transparent"
                Background="Transparent"
                Cursor="Hand"
                Command="{Binding MessageCleaningCommand}"
                HorizontalContentAlignment="Left"
                Classes="SelectedMore">
                <Button.Content>
                    <TextBlock Text="Очистить историю" FontWeight="400" FontSize="13" Padding="15 0" />
                </Button.Content>
            </Button>

            <Button
                automation:AutomationProperties.AutomationId="HeaderOpenSettingsButton"
                Width="200"
                Height="30"
                BorderBrush="Transparent"
                Background="Transparent"
                Cursor="Hand"
                Command="{Binding SettingsViewModel.OpenSettingsCommand}"
                HorizontalContentAlignment="Left"
                Classes="SelectedMore">
                <Button.Content>
                    <TextBlock Text="Настройки" FontWeight="400" FontSize="13" Padding="15 0" />
                </Button.Content>
            </Button>
        </WrapPanel>
    </Border>
</UserControl>
