<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:interactivity="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
             xmlns:viewModel="clr-namespace:SkillChat.Client.ViewModel;assembly=SkillChat.Client.ViewModel"
             xmlns:core="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
             x:Class="SkillChat.Client.Views.Settings.Settings"
             automation:AutomationProperties.AutomationId="SettingsPanelRoot"
             Name="Settings">

    <interactivity:Interaction.Behaviors>
        <!--  Settings  -->
        <core:EventTriggerBehavior EventName="PointerPressed"  SourceObject="{Binding #Settings}">
            <core:InvokeCommandAction Command="{Binding MorePointerPressedCommand}" CommandParameter="{Binding #Settings}" />
        </core:EventTriggerBehavior>
    </interactivity:Interaction.Behaviors>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid Background="{DynamicResource DividerBrush}" Grid.Row="0" />

        <Grid Background="{DynamicResource DividerBrush}" Grid.Row="2" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="2" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Background="{DynamicResource SidebarBackgroundBrush}" Grid.Column="0">
                <StackPanel>
                    <Button Height="35"
                            automation:AutomationProperties.AutomationId="SettingsMainTabButton"
                            Content="Сообщения и чаты"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            Cursor="Hand"
                            FontSize="15"
                            Classes="SettingItems"
                            FontWeight="600"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Command="{Binding GetSettingsCommand}"
                            Padding="20 0 0 0"/>

                    <Button Height="35"
                            automation:AutomationProperties.AutomationId="SettingsAuditTabButton"
                            Content="Аудит входа"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            Cursor="Hand"
                            FontSize="15"
                            Classes="SettingItems"
                            FontWeight="600"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Padding="20 0 0 0"
                            Command="{Binding GetHistoryLoginAuditCommand}"/>
                </StackPanel>
            </Grid>

            <Grid Background="{DynamicResource CardBackgroundBrush}"
                  Grid.Column="3"
                  IsVisible="{Binding SettingsMenuActiveMain}"
                  ZIndex="10"
                  automation:AutomationProperties.AutomationId="SettingsMainContent">
                <WrapPanel>
                    <TextBlock
                        Margin="20 10 0 0"
                        Background="Transparent"
                        Cursor="Hand"
                        FontSize="15"
                        FontWeight="600"
                        Foreground="{DynamicResource PrimaryTextBrush}"
                        Text="Отправлять сообщения клавишей" />
                    <RadioButton Margin="25 6 0 0" Cursor="Hand" Command="{Binding SaveSettingsCommand}" Content="Enter"
                                 GroupName="TypeMessages" IsChecked="{Binding TypeEnter}" FontWeight="600"
                                 FontSize="16" />
                    <RadioButton Margin="25 6 0 0" Cursor="Hand" Command="{Binding SaveSettingsCommand}"
                                 Content="Ctrl+Enter"
                                 GroupName="TypeMessages" IsChecked="{Binding !TypeEnter}" FontWeight="600"
                                 FontSize="16" />
                </WrapPanel>
            </Grid>

            <Grid Background="{DynamicResource CardBackgroundBrush}"
                  Grid.Column="3"
                  IsVisible="{Binding AuditMenuActiveMain}"
                  ZIndex="10"
                  automation:AutomationProperties.AutomationId="SettingsAuditContent">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl
                        automation:AutomationProperties.AutomationId="SettingsAuditListRoot"
                        Margin="15,0"
                        BorderThickness="0"
                        ItemsSource="{Binding LoginAuditCollection}">
                        <ItemsControl.DataTemplates>
                            <DataTemplate DataType="{x:Type viewModel:LoginAuditViewModel}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Grid Grid.Column="0">
                                        <StackPanel>
                                            <TextBlock
                                                Margin="0 10 0 0"
                                                Background="Transparent"
                                                FontSize="14"
                                                FontWeight="600"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                Text="{Binding NameVersionClient}" />
                                            <TextBlock
                                                Margin="0 3 0 0"
                                                Background="Transparent"
                                                FontSize="14"
                                                FontWeight="600"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                Text="{Binding OperatingSystem}" />
                                            <TextBlock
                                                Margin="0 3 0 0"
                                                FontSize="14"
                                                FontWeight="600"
                                                Foreground="{DynamicResource SecondaryTextBrush}"
                                                Text="{Binding IpAddress}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid Grid.Column="1">
                                        <WrapPanel>
                                            <TextBlock
                                                Margin="0 10 10 0"
                                                Foreground="{DynamicResource AccentBrush}"
                                                FontWeight="400"
                                                FontSize="13"
                                                Text="{Binding IsActive}"/>
                                            <TextBlock
                                                Margin="0 10 0 0"
                                                HorizontalAlignment="Right"
                                                TextAlignment="Right"
                                                FontWeight="400"
                                                FontSize="13"
                                                Text="{Binding DateOfEntry}"
                                                Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </WrapPanel>
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.DataTemplates>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
