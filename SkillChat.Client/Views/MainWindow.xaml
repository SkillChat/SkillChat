<Window
    x:Class="SkillChat.Client.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
    xmlns:viewModel="clr-namespace:SkillChat.Client.ViewModel;assembly=SkillChat.Client.ViewModel"
    xmlns:views="clr-namespace:SkillChat.Client.Views"
    xmlns:profile="clr-namespace:SkillChat.Client.Views.Profile"
    xmlns:settings="clr-namespace:SkillChat.Client.Views.Settings"
    xmlns:interactivity="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
    xmlns:core="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
    xmlns:utils="clr-namespace:SkillChat.Client.Utils"
    Title="{Binding Title}"
    Name="WindowChat"
    Width="900"
    Height="600"
    MinWidth="500"
    MinHeight="600"
    Icon="/Assets/skillchat-logo.ico"
    mc:Ignorable="d">
    <Design.DataContext>
        <viewModel:DesignMainWindowViewModel/>
    </Design.DataContext>

  <interactivity:Interaction.Behaviors>
    <!--  Notify  -->
    <core:EventTriggerBehavior EventName="LostFocus" SourceObject="{Binding #WindowChat}">
      <core:InvokeCommandAction Command="{Binding NotifyCommand}" CommandParameter="{Binding #WindowChat}" />
    </core:EventTriggerBehavior>
      <!--  Notify  -->
      <core:EventTriggerBehavior EventName="GotFocus" SourceObject="{Binding #WindowChat}">
          <core:InvokeCommandAction Command="{Binding NotifyCommand}" CommandParameter="{Binding #WindowChat}" />
     </core:EventTriggerBehavior>
    <!--  Profile  -->
    <core:EventTriggerBehavior EventName="LayoutUpdated" SourceObject="{Binding #WindowChat}">
      <core:InvokeCommandAction Command="{Binding ProfileViewModel.LayoutUpdatedWindow}" CommandParameter="{Binding #WindowChat}" />
    </core:EventTriggerBehavior>
      <!--  Settings  -->
      <core:EventTriggerBehavior EventName="PointerPressed"  SourceObject="{Binding #WindowChat}">
            <core:InvokeCommandAction Command="{Binding PointerPressedCommand}" CommandParameter="{Binding #WindowChat}" />
      </core:EventTriggerBehavior>
  </interactivity:Interaction.Behaviors>

    <Window.Resources>
        <utils:GridLengthValueConverter x:Key="GridLengthValueConverter" />
    </Window.Resources>

    <Window.Styles>
        <!-- Telegram-style thin scrollbar -->
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Width" Value="6" />
            <Setter Property="Margin" Value="-6,0,0,0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent" UseLayoutRounding="False">
                        <Grid>
                            <Track
                                IsDirectionReversed="True"
                                Maximum="{TemplateBinding Maximum}"
                                Minimum="{TemplateBinding Minimum}"
                                Orientation="{TemplateBinding Orientation}"
                                ViewportSize="{TemplateBinding ViewportSize}"
                                Value="{TemplateBinding Value, Mode=TwoWay}">
                                <Thumb Name="thumb">
                                    <Thumb.Template>
                                        <ControlTemplate>
                                            <Border />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ScrollBar:vertical /template/ Thumb Border">
            <Setter Property="Background" Value="{DynamicResource ScrollbarThumbBrush}" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Width" Value="6" />
        </Style>
        <Style Selector="ScrollBar:vertical:pointerover /template/ Thumb Border">
            <Setter Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}" />
        </Style>
        
        <!-- Sidebar button styles -->
        <Style Selector="Button.sidebar-btn">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="Button.sidebar-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource SidebarHoverBrush}" />
        </Style>
        <Style Selector="Button.sidebar-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource SidebarActiveBrush}" />
        </Style>
        <Style Selector="Button.sidebar-btn.active">
            <Setter Property="Background" Value="{DynamicResource SidebarActiveBrush}" />
        </Style>
    </Window.Styles>
    
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding SidebarWidth}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Left Sidebar - Telegram style -->
            <Border Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource DividerBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Sidebar Header with logo and hamburger menu area - clickable to toggle sidebar -->
                    <Button Grid.Row="0"
                            Command="{Binding ToggleSidebarCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="12,12,12,8"
                            Cursor="Hand"
                            HorizontalContentAlignment="Stretch">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <!-- Hamburger icon / Logo -->
                            <TextBlock Text="☰"
                                       FontSize="20"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding !IsSidebarExpanded}"/>
                            <Image Width="32" Height="32"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsSidebarExpanded}">
                                <Image.Source>
                                    <svg:SvgImage Source="/Assets/SkillChat_small.svg" />
                                </Image.Source>
                            </Image>

                            <!-- App title - only visible when expanded -->
                            <TextBlock Grid.Column="1" 
                                       Text="SkillChat"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       IsVisible="{Binding IsSidebarExpanded}"/>
                        </Grid>
                    </Button>
                    
                    <!-- Sidebar Content - Chat list area (placeholder for future chat list) -->
                    <Border Grid.Row="1" Background="Transparent" IsVisible="{Binding IsSidebarExpanded}">
                        <StackPanel Margin="8,4">
                            <!-- Chats button - primary navigation -->
                            <Button Classes="sidebar-btn"
                                    IsVisible="{Binding !IsChatsSelected}"
                                    Command="{Binding ShowChatsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="💬" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Чаты"
                                               FontSize="14"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn active"
                                    IsVisible="{Binding IsChatsSelected}"
                                    Command="{Binding ShowChatsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="💬" FontSize="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Чаты"
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Profile button -->
                            <Button Classes="sidebar-btn"
                                    IsVisible="{Binding !IsProfileSelected}"
                                    Command="{Binding ProfileViewModel.OpenProfilePanelCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Width="20" Height="20" Name="profile_white_icon" />
                                    <TextBlock Text="Профиль" 
                                               FontSize="14"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn active"
                                    IsVisible="{Binding IsProfileSelected}"
                                    Command="{Binding ProfileViewModel.OpenProfilePanelCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Width="20" Height="20" Name="profile_orange_icon" />
                                    <TextBlock Text="Профиль" 
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            
                            <!-- Settings button -->
                            <Button Classes="sidebar-btn"
                                    IsVisible="{Binding !IsSettingsSelected}"
                                    Command="{Binding SettingsViewModel.OpenSettingsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Width="20" Height="20" Name="settings" />
                                    <TextBlock Text="Настройки" 
                                               FontSize="14"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="sidebar-btn active"
                                    IsVisible="{Binding IsSettingsSelected}"
                                    Command="{Binding SettingsViewModel.OpenSettingsCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Image Width="20" Height="20" Name="settings_active" />
                                    <TextBlock Text="Настройки" 
                                               FontSize="14"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <!-- Bottom area with Night Mode toggle -->
                    <Border Grid.Row="2" 
                            Background="{DynamicResource SidebarBackgroundBrush}"
                            BorderBrush="{DynamicResource DividerBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="12,12"
                            IsVisible="{Binding IsSidebarExpanded}">
                        <StackPanel Spacing="8">
                            <!-- Night Mode toggle -->
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="🌙" FontSize="16" VerticalAlignment="Center"/>
                                    <TextBlock Text="Ночной режим" 
                                               FontSize="14"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="1"
                                              IsChecked="{Binding SettingsViewModel.IsDarkTheme, Mode=TwoWay}"
                                              OffContent=""
                                              OnContent=""
                                              Margin="0"
                                              Padding="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1" RowDefinitions="Auto,*">

                <!-- Header - Telegram style thin header -->
                <Border Grid.Row="0" 
                        ZIndex="1" 
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        BorderBrush="{DynamicResource HeaderBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="0">
                    <Grid Height="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition
                                Width="{Binding ColumndefinitionWidth,Converter={StaticResource GridLengthValueConverter}}" />
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition
                                Width="{Binding ColumndefinitionWidth2,Converter={StaticResource GridLengthValueConverter}}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Информация о чате  -->
                        <StackPanel
                            Grid.Column="0"
                            Margin="16,8"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                            <!--  Название чата/настройки  -->
                            <TextBlock
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource HeaderTextBrush}"
                                Text="{Binding TextHeaderMain}" />
                            <!--  Участники чата  -->
                            <TextBlock
                                FontSize="13"
                                FontWeight="Regular"
                                Foreground="{DynamicResource HeaderSubtextBrush}"
                                Text="{Binding MembersCaption}"
                                TextTrimming="WordEllipsis" />
                        </StackPanel>

                        <Grid ZIndex="1" Grid.Column="2">
                            <!--  Выбранные настройки  -->
                            <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
                                <TextBlock Foreground="{DynamicResource HeaderTextBrush}"
                                           FontWeight="600"
                                           IsVisible="{Binding SettingsActive}"
                                           VerticalAlignment="Center" 
                                           Margin="16,0,0,0"
                                           FontSize="15" 
                                           Text="{Binding TextHeaderMenuInSettings}"/>
                            </StackPanel>
                        </Grid>
                          <Grid ZIndex="1" Grid.Column="4">
                              <!--  Информация о профиле -->
                            <Grid ZIndex="1" Width="300" Height="300" HorizontalAlignment="Right">
                               <profile:Header DataContext="{Binding ProfileViewModel}" />
                            </Grid>
                            <!--  Профиль - выход -->
                             <Grid ZIndex="2" Width="140" Height="30" HorizontalAlignment="Right">
                                <profile:Exit DataContext="{Binding ProfileViewModel}" />
                            </Grid>
                            <!--  Настройки - Header -->
                            <Grid ZIndex="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                                  Margin="0,6,16,0" Width="40" Height="40" Background="Transparent">
                                <settings:Header DataContext="{Binding SettingsViewModel}" />
                            </Grid>
                            <!--  Настройки - Panel -->
                            <Grid ZIndex="2" IsHitTestVisible="{Binding SettingsViewModel.IsContextMenu}"
                                  HorizontalAlignment="Right" VerticalAlignment="Top" Width="200" Height="93"
                                  Margin="0,47,47,0" Background="Transparent">
                                <settings:More/>
                            </Grid>
                          </Grid>

                    </Grid>
                </Border>

                <!--  Окно настроек  -->
                <Grid Grid.Row="1" IsVisible="{Binding SettingsViewModel.IsOpened}">
                    <settings:Settings DataContext="{Binding SettingsViewModel}" />
                </Grid>
                
                <!--  Message Area - Solid themed background  -->
                <Grid Grid.Row="1" ZIndex="-1" ColumnDefinitions="*,Auto"
                      Background="{DynamicResource MessageAreaBackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  Блок списка сообщений  -->
                    <Grid
                        Grid.Row="0"
                        Grid.Column="0"
                        IsVisible="{Binding ProfileViewModel.IsShowChat}" ZIndex="-1">
                        <ScrollViewer Name="MessagesSV" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl
                                Grid.Row="3"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Margin="16,0"
                                VerticalAlignment="Bottom"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding Messages}">
                                <ItemsControl.DataTemplates>
                                    <!--  Messages  -->
                                    <DataTemplate DataType="{x:Type viewModel:MessageViewModel}">
                                        <views:Messages/>
                                    </DataTemplate>
                                </ItemsControl.DataTemplates>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                    
                    <!-- Attachment menu popup -->
                    <Border 
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="10,0,0,0"
                        MaxWidth="160"
                        ZIndex="10"
                        BorderThickness="1"
                        CornerRadius="8"
                        BorderBrush="{DynamicResource MenuBorderBrush}"
                        Background="{DynamicResource MenuBackgroundBrush}"
                        Grid.Row="0" 
                        x:Name="AttachButtons" 
                        IsVisible="{Binding AttachMenuVisible}">
                        <StackPanel 
                            Orientation="Vertical" 
                            x:Name="AttachMenuList">
                            <Button 
                                Cursor="Hand"
                                Background="{DynamicResource MenuBackgroundBrush}"
                                HorizontalContentAlignment="Left"
                                BorderThickness="0"
                                Padding="12,10"
                                x:Name="AttachFile" 
                                Command="{Binding AttachFileClick}">
                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        Cursor="Hand"
                                        Background="Transparent"
                                        HorizontalContentAlignment="Left"
                                        BorderThickness="0"
                                        Classes="AttachMenu" 
                                        x:Name="OpenFileBrowserMenu" 
                                        Command="{Binding OpenFileBrowserMenu}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Image Name="FileImage" Width="16" Height="18.5" Classes="FileImage"/>
                                            <TextBlock Text="Файл" 
                                                       FontSize="14"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <!--  Блок отправки сообщения  -->
                    <views:SelectMessageBorderControl Grid.Column="0" Grid.Row="2" IsVisible="{Binding SelectMessagesMode.IsTurnedSelectMode}"/>	
                    <views:SendMessageControl Grid.Column="0" Grid.Row="2" ZIndex="-1" IsVisible="{Binding !SelectMessagesMode.IsTurnedSelectMode}"/>                 
                    
                    <!--Profile - panel -->
                    <Grid Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" Background="{DynamicResource SidebarBackgroundBrush}">
                        <profile:Settings DataContext="{Binding ProfileViewModel}" />
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <views:Confirmation IsVisible="{Binding IsOpened, Mode=OneWay}" DataContext="{Binding ConfirmationViewModel}"/>
        <views:AttachmentView IsVisible="{Binding IsOpen, Mode=OneWay}" DataContext="{Binding AttachmentViewModel}"/>
        <views:LoginPage VerticalAlignment="Stretch" IsVisible="{Binding IsShowingLoginPage, Mode=OneWay}" />
        <views:RegisterPage VerticalAlignment="Stretch" IsVisible="{Binding IsShowingRegisterPage, Mode=OneWay}" />
    </Grid>
</Window>
