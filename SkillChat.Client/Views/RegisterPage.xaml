<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:automation="clr-namespace:Avalonia.Automation;assembly=Avalonia.Controls"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
    xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
    xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
  mc:Ignorable="d"
  Background="{DynamicResource PageBackgroundBrush}"
  automation:AutomationProperties.AutomationId="RegisterPage"
  x:Class="SkillChat.Client.Views.RegisterPage">

  <Grid Background="{DynamicResource PageBackgroundBrush}">
    <Grid ShowGridLines="False"
          Margin="0 0"
          MaxWidth="380"
          MaxHeight="600"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          RowDefinitions="150,320,130">
        <Image
            MaxWidth="180"
            MaxHeight="130"
            Margin="86,6,86,0"
            Stretch="Uniform">
        <Image.Source>
          <svg:SvgImage Source="/Assets/SkillChat_big.svg" />
        </Image.Source>
      </Image>

      <StackPanel
          Grid.Row="1"
          MaxWidth="380"
          MaxHeight="293"
          HorizontalAlignment="Center"
          Margin="0 30 0 0 ">

        <StackPanel>
          <TextBlock Name="LoginTextBlock"
                     Classes="UpperWatermark"
                     Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}"
                     Text="Логин" />

          <Border Background="{DynamicResource PageBackgroundBrush}"
                  Name="LoginBorder"
                  Classes="BorderEnterPages Base"
                  Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}">
            <TextBox
                Name="LoginTextBox"
                automation:AutomationProperties.AutomationId="RegisterLoginInput"
                Classes="TextBoxEnterPages Base"
                Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}"
                Text="{Binding RegisterUser.Login}">
                <i:Interaction.Behaviors>
                    <ia:EventTriggerBehavior EventName="KeyDown" SourceObject="{Binding #LoginTextBox}">
                        <ia:InvokeCommandAction Command="{Binding ResetErrorCommand}" CommandParameter="{x:Null}" />
                    </ia:EventTriggerBehavior>
                </i:Interaction.Behaviors>
            </TextBox>
          </Border>
        </StackPanel>

        <StackPanel
          Margin="0,7,0,0">
          <TextBlock Name="PasswordTextBlock"
                     Classes="UpperWatermark"
                     Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}"
                     Text="Пароль" />
          <Border Background="{DynamicResource PageBackgroundBrush}"
                  Name="PasswordBorder"
                  Classes="BorderEnterPages Base"
                  Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}">
            <TextBox
                Name="PasswordTextBox"
                automation:AutomationProperties.AutomationId="RegisterPasswordInput"
                Classes="TextBoxEnterPages Base"
                Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}"
                PasswordChar="*"
                Text="{Binding RegisterUser.Password}">
                <i:Interaction.Behaviors>
                    <ia:EventTriggerBehavior EventName="KeyDown" SourceObject="{Binding #PasswordTextBox}">
                        <ia:InvokeCommandAction Command="{Binding ResetErrorCommand}" CommandParameter="{x:Null}" />
                    </ia:EventTriggerBehavior>
                </i:Interaction.Behaviors>
            </TextBox>
          </Border>
        </StackPanel>

        <StackPanel
          Margin="0,7,0,0">
          <TextBlock Name="NickNameTextBlock"
                     Classes="UpperWatermark"
                     Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}"
                     Text="Имя" />
          <Border Background="{DynamicResource PageBackgroundBrush}"
                  Name="NickNameBorder"
                  Classes="BorderEnterPages Base"
                  Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}">
              <TextBox
                  Name="NickNameTextBox"
                  automation:AutomationProperties.AutomationId="RegisterNameInput"
                  Classes="TextBoxEnterPages Base"
                  Classes.Error="{Binding RegisterUser.ErrorMessageRegisterPage.IsError}"
                  Text="{Binding RegisterUser.UserName}"/>
          </Border>
        </StackPanel>

        <StackPanel
          Orientation="Vertical"
          HorizontalAlignment="Stretch"
          Margin="0,19,0,5">
          <CheckBox
            automation:AutomationProperties.AutomationId="RegisterConsentCheckBox"
            FontSize="12"
            Foreground="{DynamicResource SecondaryTextBrush}"
            FontWeight="400"
            FontStyle="Italic"
            BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1"
            IsChecked="{Binding RegisterUser.Consent}"
            Padding="3,0,0,0"
            Content="Согласен на обработку персональных данных"/>

          <TextBlock
              automation:AutomationProperties.AutomationId="RegisterErrorLabel"
              automation:AutomationProperties.Name="{Binding RegisterUser.ErrorMessageRegisterPage.ErrorMsg}"
              Height="15"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              FontStyle="Italic"
              FontSize="13"
              FontWeight="400"
              Foreground="{DynamicResource ErrorBrush}"
              Text="{Binding RegisterUser.ErrorMessageRegisterPage.ErrorMsg}"/>
        </StackPanel>
      </StackPanel>
        <StackPanel Grid.Row="2">
          <Button
                Classes="ButtonEnterPages"
                automation:AutomationProperties.AutomationId="RegisterSubmitButton"
                automation:AutomationProperties.Name="Зарегистрироваться"
                MinWidth="300"
                MaxWidth="300"
                Margin="0,10,0,20"
                Padding="0 10 0 10"
                BorderThickness="3"
                Command="{Binding RegisterCommand}"
                Content="Зарегистрироваться"
                IsEnabled="{Binding RegisterUser.Consent}"/>
            <Button
                x:Name="registerLinkButton"
                automation:AutomationProperties.AutomationId="BackToLoginButton"
                automation:AutomationProperties.Name="Войти"
                Margin="0,0,0,32"
                HorizontalAlignment="Center"
                Classes="ClearContainer"
                Command="{Binding RegisterUser.GoToLoginCommand}"
                Content="Войти"/>
        </StackPanel>
    </Grid>
  </Grid>
</UserControl>
