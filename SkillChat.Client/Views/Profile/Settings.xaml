<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="450"
             xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia"
             xmlns:viewModel="clr-namespace:SkillChat.Client.ViewModel;assembly=SkillChat.Client.ViewModel"
             x:Class="SkillChat.Client.Views.Profile.Settings">

    <!--Profile - panel -->
    <Grid IsVisible="{Binding IsOpened}" Background="{DynamicResource CardBackgroundBrush}" HorizontalAlignment="Right" MaxWidth="390">
        <Grid Width="2" Background="{DynamicResource DividerBrush}" HorizontalAlignment="Left" />

        <!-- Close button at top-right -->
        <Button VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,8,12,0"
                Width="28"
                Height="28"
                Background="Transparent"
                BorderThickness="0"
                Cursor="Hand"
                Command="{Binding CloseProfilePanelCommand}"
                ToolTip.Tip="Закрыть">
            <TextBlock Text="✕"
                       FontSize="16"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Button>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel>
                <Grid Grid.Row="0">

                    <TextBlock Margin="50 5 0 0" FontStyle="Italic"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontWeight="400" FontSize="14" Text="Имя" />

                    <TextBlock Margin="50 43 50 0" FontStyle="Normal" IsVisible="{Binding !IsEditNameProfile}"
                               HorizontalAlignment="Stretch"
                               TextAlignment="Center"
                               MinHeight="50"
                               MaxHeight="100"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="600" FontSize="16" Text="{Binding DisplayName}" />

                    <TextBox HorizontalAlignment="Stretch" IsVisible="{Binding IsEditNameProfile}"
                             Text="{Binding DisplayName}"
                             AcceptsReturn="True"
                             MinHeight="50"
                             MaxHeight="100"
                             TextWrapping="Wrap"
                             Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="600" FontSize="16" VerticalContentAlignment="Center"
                             MaxLength="32" BorderBrush="{DynamicResource DividerBrush}" Margin="50 29 50 0"
                             VerticalAlignment="Top" />
                    <Grid IsVisible="{Binding IsMyProfile}">
                        <Button
                            IsVisible="{Binding !IsEditNameProfile}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Margin="0 35.67 20 0"
                            Cursor="Hand"
                            Classes="profile_edit"
                            BorderThickness="0"
                            Command="{Binding SetEditNameProfileCommand}">
                            <Image
                                Name="buttonImagePencil"
                                Width="19.33"
                                Height="18.67" />
                        </Button>
                        <Button
                            IsVisible="{Binding IsEditNameProfile}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Margin="0 48 21.33 0"
                            Cursor="Hand"
                            Classes="profile_save"
                            BorderThickness="0"
                            Command="{Binding ApplyProfileNameCommand}">
                            <Image
                                Name="buttonImageSave"
                                Width="17.33"
                                Height="11.33" />
                        </Button>
                    </Grid>

                </Grid>

                <Grid Grid.Row="1">
                    <TextBlock Margin="50 20 0 0" FontStyle="Italic"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontWeight="400" FontSize="14" Text="О себе" />

                    <TextBlock Margin="50 44 50 0" FontStyle="Normal" IsVisible="{Binding !IsEditAboutMeProfile}"
                               HorizontalAlignment="Stretch"
                               TextAlignment="Center"
                               MinHeight="50"
                               MaxHeight="250"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="600" FontSize="16" Text="{Binding AboutMe}" />


                    <TextBox HorizontalAlignment="Stretch" IsVisible="{Binding IsEditAboutMeProfile}"
                             Text="{Binding AboutMe}"
                             AcceptsReturn="True"
                             Foreground="{DynamicResource SecondaryTextBrush}" FontWeight="600" FontSize="16"
                             TextWrapping="Wrap"
                             MinHeight="50"
                             MaxHeight="250"
                             BorderBrush="{DynamicResource DividerBrush}" Margin="50 44 50 0"
                             VerticalAlignment="Top" />
                    <Grid IsVisible="{Binding IsMyProfile}">
                        <Button
                            IsVisible="{Binding !IsEditAboutMeProfile}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Margin="0 60 20 0"
                            Cursor="Hand"
                            Classes="profile_edit"
                            BorderThickness="0"
                            Command="{Binding SetEditAboutMeProfileCommand}">
                            <Image
                                Name="buttonImagePencil2"
                                Width="19.33"
                                Height="18.67" />
                        </Button>
                        <Button
                            IsVisible="{Binding IsEditAboutMeProfile}"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            Margin="0 60 21.33 0"
                            Cursor="Hand"
                            Classes="profile_save"
                            BorderThickness="0"
                            Command="{Binding ApplyProfileAboutMeCommand}">
                            <Image
                                Name="buttonImageSave2"
                                Width="17.33"
                                Height="11.33" />
                        </Button>
                    </Grid>
                </Grid>
                <Grid Grid.Row="2" Width="390">
                    <TextBlock Margin="0 20 0 0" Padding="0 0 1 0" 
                               HorizontalAlignment="Center" FontStyle="Italic"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontWeight="400" FontSize="16" Text="{Binding Login}" />
                    <Button
                        VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding IsMyProfile}"
                        Margin="0 50"
                        FontWeight="400"
                        Height="30"
                        Width="149"
                        Cursor="Hand"
                        Background="Transparent"
                        Classes="profile_exit"
                        BorderThickness="0"
                        Command="{Binding SignOutCommand}"
                        Content="Выйти из профиля"
                        FontSize="16" />
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>

</UserControl>
